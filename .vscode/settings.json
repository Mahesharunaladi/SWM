{
    "python.defaultInterpreterPath": "${workspaceFolder}/ml-service/venv/bin/python",
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": false,
    "python.linting.flake8Enabled": true,
    "python.formatting.provider": "black",
    "python.terminal.executeInFileDir": true,
    "[python]": {
        "editor.defaultFormatter": "ms-python.python",
        "editor.formatOnSave": true
    },
    "css.lint.unknownAtRules": "ignore",
    "[java]": {
        "validate.enable": false
    },
    "redhat.telemetry.enabled": false,
    "files.exclude": {
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/bin": true,
        "**/.factorypath": true,
        "**/.apt_generated": true,
        "**/target": true
    },
    "java.server.launchMode": "Standard",
    "java.configuration.updateBuildConfiguration": "interactive",
    "java.help.firstStart": false,
    "java.trace.server": "off",
    "java.errors.incompleteClasspath.severity": "ignore",
    "java.warnings.incompleteClasspath": "ignore",
    "java.checkstyle.enable": false,
    "java.saveActionsOnOrganizeImports": [],
    "java.project.referencedLibraries": [],
    "java.eclipse.downloadSources": false,
    "java.implementation.goto.location": "definition",
    "java.maven.downloadSources": false,
    "java.sources.organizeImports.starThreshold": 999,
    "java.completion.filteredTypes": [
        "java.awt.*",
        "com.sun.*",
        "sun.*",
        "jdk.internal.*"
    ],
    "problems.showCurrentInStatus": false,
    "problems.shortenProblemLabel": true,
    "java.diagnostics.performanceLogging.enabled": false,
    "java.refactoring.rename.preview": false,
    "java.codeGeneration.useBlockStatements": true,
    "java.jdt.ls.vmargs": "-XX:+UseG1GC -XX:+UseStringDeduplication -Xmx2G",
    "extensions.ignoreRecommendations": true,
    "[xml]": {
        "xml.validate": false
    },
    "java.compile.nullAnalysis.mode": "automatic",
    "extensions.recommendations": [],
    "security.workspace.trust.enabled": false
}